# MongoDB Configuration
MONGODB_URI=your_mongodb_connection_string_here

# JWT Secret (generate a random string)
JWT_SECRET_KEY=your_secret_key_here

# Email Configuration (Gmail recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_SECURE=true

# Cloudinary Configuration
# Get these from: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Server IP (Auto-updated when server starts)
# No need to manually set this unless you want to override
SERVER_IP=localhost

# ── Mastercard MPGS ─────────────────────────────────────────────────────────
MASTERCARD_CONSUMER_KEY=your_consumer_key_here
MASTERCARD_SIGNING_KEY_PATH=certs/Nursify-sandbox-signing.p12
MASTERCARD_SIGNING_KEY_PASSWORD=keystorepassword
MASTERCARD_MERCHANT_ID=
MASTERCARD_API_PASSWORD=
MASTERCARD_GATEWAY_URL=https://test-akamai.gateway.mastercard.com
MASTERCARD_API_VERSION=61

# HMAC-SHA256 secret configured in the MPGS merchant portal for webhook notifications.
# Leave blank in sandbox when MPGS notification URL is not yet configured
# (signature verification is skipped automatically).
MPGS_WEBHOOK_SECRET=

# ── Wallet ───────────────────────────────────────────────────────────────────
# Minimum PKR amount a nurse can withdraw from their wallet
MIN_WITHDRAWAL_PKR=500

# ========================================
# Setup Instructions:
# ========================================
#
# 1. MongoDB:
#    - Sign up at https://www.mongodb.com/cloud/atlas
#    - Create a cluster
#    - Get connection string and replace MONGODB_URI
#
# 2. Gmail App Password:
#    - Go to Google Account → Security
#    - Enable 2-Step Verification
#    - Generate App Password
#    - Use app password in SMTP_PASS
#
# 3. Cloudinary:
#    - Sign up at https://cloudinary.com/
#    - Go to Dashboard
#    - Copy Cloud Name, API Key, and API Secret
#
# 4. JWT Secret:
#    - Generate random string (e.g., use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
#
